    "@radix-ui/react-slot": "1.3.0",
    "@tailwindcss/vite": "4.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "immer": "11.1.8",
    "lucide-react": "1.18.0",
    "next-themes": "0.4.6",
